---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import StickyOffer from '../components/StickyOffer.astro';

interface Props {
	title: string;
	description?: string;
}

const { title, description = "R&D Bouwgroep - Waar luxe en comfort samenkomen in uw badkamer, zwembad of wellnessruimte." } = Astro.props;
---

<!doctype html>
<html lang="nl">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/png" href="/favicon.png" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<Header />
		<main>
			<slot />
		</main>
		<StickyOffer />
		<Footer />

		<!-- Easter egg: Konami code (↑↑↓↓←→←→BA) reveals the ballerina team photo -->
		<div id="ballerina-egg" aria-hidden="true">
			<img src="/Teamfotos%20R%26D/Teamfoto%20grappig%20ai%20ballerina%20versie%20van%20normaal.jpeg" alt="" />
			<span class="egg-caption">Je hebt het geheim van R&amp;D ontdekt 🩰</span>
		</div>

		<script is:inline>
			(() => {
				const code = ['ArrowUp','ArrowUp','ArrowDown','ArrowDown','ArrowLeft','ArrowRight','ArrowLeft','ArrowRight','b','a'];
				let idx = 0;
				const egg = document.getElementById('ballerina-egg');
				if (!egg) return;
				const trigger = () => {
					egg.classList.add('is-active');
					setTimeout(() => egg.classList.remove('is-active'), 5000);
				};
				window.addEventListener('keydown', (e) => {
					const key = e.key.length === 1 ? e.key.toLowerCase() : e.key;
					if (key === code[idx]) {
						idx++;
						if (idx === code.length) { trigger(); idx = 0; }
					} else {
						idx = key === code[0] ? 1 : 0;
					}
				});
			})();
		</script>

	</body>
</html>

<style is:global>
	#ballerina-egg {
		position: fixed;
		inset: 0;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 1.5rem;
		background: radial-gradient(circle at center, rgba(227,6,19,0.25), rgba(0,0,0,0.85));
		backdrop-filter: blur(8px);
		-webkit-backdrop-filter: blur(8px);
		z-index: 9999;
		opacity: 0;
		pointer-events: none;
		transition: opacity 0.4s ease;
	}
	#ballerina-egg.is-active {
		opacity: 1;
	}
	#ballerina-egg img {
		max-width: min(80vw, 520px);
		max-height: 70vh;
		border-radius: 12px;
		box-shadow: 0 30px 80px rgba(0,0,0,0.5);
		transform: scale(0.6) rotate(-8deg);
	}
	#ballerina-egg.is-active img {
		animation: ballerinaSpin 1.2s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
	}
	.egg-caption {
		color: #fff;
		font-family: var(--font-heading, sans-serif);
		font-size: 1.25rem;
		letter-spacing: 0.5px;
		text-shadow: 0 2px 20px rgba(0,0,0,0.6);
		transform: translateY(10px);
		opacity: 0;
		transition: all 0.5s ease 0.4s;
	}
	#ballerina-egg.is-active .egg-caption {
		transform: translateY(0);
		opacity: 1;
	}
	@keyframes ballerinaSpin {
		0%   { transform: scale(0.4) rotate(-20deg); }
		60%  { transform: scale(1.05) rotate(4deg); }
		100% { transform: scale(1) rotate(0deg); }
	}
</style>
