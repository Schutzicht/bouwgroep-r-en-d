---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Zwembaden & Wellness | R&D Bouwgroep">
  <div class="page-header">
    <div class="container">
      <h1>Zwembaden & <span class="text-primary">Wellness</span></h1>
      <p class="lead">Haal het vakantiegevoel in huis met uw eigen privé wellness.</p>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <div class="split-content">
        <div class="text-col">
          <h2>Ultieme <span class="text-primary">Ontspanning</span></h2>
          <p>
            Een zwembad (binnen of buiten) is de ultieme toevoeging aan uw woning. R&D Bouwgroep realiseert 
            bouwkundige zwembaden op maat. Geen standaard kunststof bakken, maar duurzame constructies, 
            perfect betegeld en afgewerkt.
          </p>
          
          <div class="features-grid">
            <div class="feature-card">
              <h3>Binnenzwembaden</h3>
              <p>Volledig geïntegreerd in uw woning, inclusief klimaatbeheersing en wellness faciliteiten.</p>
            </div>
            <div class="feature-card">
              <h3>Buitenzwembaden</h3>
              <p>Prachtig aangelegde baden die één geheel vormen met uw tuin en terras.</p>
            </div>
          </div>

          <h3>Techniek & Afwerking</h3>
          <p>
            Naast de bouwkundige realisatie verzorgen wij ook de technische installatie (pompen, filters, verwarming) 
            en de esthetische afwerking. Denk aan mozaïek tegels, natuursteen randafwerking en sfeerverlichting.
          </p>

          <a href="/offerte-aanvragen" class="btn" style="margin-top: 2rem;">Adviesgesprek aanvragen</a>
        </div>
        
        <div class="image-col">
          <!-- Before/After Slider Container -->
          <div class="slider-container">
            <div class="img-wrapper after">
              <img src="/images/wellness/after.png" alt="Na: Luxe Binnenzwembad afgewerkt" />
            </div>
            <div class="img-wrapper before" id="before-img">
              <img src="/images/wellness/before.png" alt="Voor: Zwembad in aanbouw" />
            </div>
            <input type="range" min="0" max="100" value="50" class="slider-input" id="slider-range" />
            <div class="slider-handle">
              <div class="handle-line"></div>
              <div class="handle-button">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
              </div>
            </div>
            <div class="labels">
              <span class="label-before">Voor</span>
              <span class="label-after">Na</span>
            </div>
          </div>

          <div class="quote-box">
             "Wij maken geen zwembad, wij creëren een beleving."
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-header {
    background-color: var(--color-light-grey);
    padding: 8rem 0 4rem;
    text-align: center;
  }

  .lead {
    font-size: 1.25rem;
    color: var(--color-text-muted);
    max-width: 600px;
    margin: 1rem auto 0;
  }

  .split-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  h2 {
    margin-bottom: 1.5rem;
  }

  .features-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    margin: 2rem 0;
  }

  .feature-card {
    background: #fdfdfd;
    padding: 1.5rem;
    overflow: hidden;
    z-index: 1;
    border-radius: var(--radius-btn);
  }

  .feature-card h3 {
    font-size: 1.1rem;
    margin-bottom: 0.5rem;
    color: var(--color-primary);
  }

  .feature-card p {
    font-size: 0.9rem;
    margin: 0;
  }

  .image-col {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    position: sticky;
    top: 120px;
  }

  /* Slider Styling */
  .slider-container {
    position: relative;
    width: 100%;
    aspect-ratio: 4/3;
    overflow: hidden;
    border-radius: var(--radius-sm);
    box-shadow: 0 20px 40px rgba(0,0,0,0.1);
  }

  .img-wrapper {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  .img-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .before {
    clip-path: inset(0 50% 0 0);
    z-index: 2;
  }

  .after {
    z-index: 1;
  }

  .slider-input {
    position: absolute;
    -webkit-appearance: none;
    appearance: none;
    width: 100%;
    height: 100%;
    background: transparent;
    outline: none;
    margin: 0;
    z-index: 10;
    cursor: ew-resize;
  }

  .slider-input::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 40px;
    height: 40px;
    background: transparent;
  }

  .slider-handle {
    position: absolute;
    top: 0;
    left: 50%;
    height: 100%;
    width: 2px;
    background: white;
    z-index: 5;
    pointer-events: none;
    transform: translateX(-50%);
  }

  .handle-button {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 44px;
    height: 44px;
    background: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 0 15px rgba(0,0,0,0.3);
    color: var(--color-primary);
    gap: 2px;
  }

  .handle-button svg {
    width: 16px;
    height: 16px;
  }

  .labels {
    position: absolute;
    bottom: 20px;
    left: 0;
    width: 100%;
    display: flex;
    justify-content: space-between;
    padding: 0 20px;
    z-index: 6;
    pointer-events: none;
  }

  .label-before, .label-after {
    background: rgba(0,0,0,0.5);
    color: white;
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    backdrop-filter: blur(4px);
  }

  .quote-box {
    text-align: center;
    font-style: italic;
    font-size: 1.2rem;
    color: var(--color-dark);
    font-family: var(--font-heading);
    padding: 2rem;
    border-top: 1px solid #eee;
    border-bottom: 1px solid #eee;
  }

  @media (max-width: 900px) {
    .split-content { grid-template-columns: 1fr; }
    .page-header { padding: 10rem 0 3rem; }
    .features-grid { grid-template-columns: 1fr; }
  }
</style>

<script>
  const slider = document.getElementById('slider-range');
  const beforeImg = document.getElementById('before-img');
  const beforeImgTag = beforeImg?.querySelector('img');
  const handle = document.querySelector('.slider-handle');

  if (slider && beforeImg && handle) {
    slider.addEventListener('input', (e) => {
      const value = e.target.value;
      beforeImg.style.clipPath = `inset(0 ${100 - value}% 0 0)`;
      handle.style.left = `${value}%`;
    });

    // Initial sync
    const initialValue = slider.value;
    beforeImg.style.clipPath = `inset(0 ${100 - initialValue}% 0 0)`;
    handle.style.left = `${initialValue}%`;
  }
</script>
